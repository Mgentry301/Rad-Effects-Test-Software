{
  "bench_name": "example_dry_run",
  "output_csv": "example_output.csv",
  "instruments": {
    "psu": { "type": "keithley2230", "resource": "GPIB0::5::INSTR" },
    "siggen": { "type": "rohde_schwarz_sma", "resource": "GPIB0::10::INSTR" },
    "scope": { "type": "fieldfox", "resource": "USB0::0x0957::0x1798::MY123456::INSTR" }
  },
  "poll_interval_s": 1.0,
  "registers": [
    { "name": "vout", "path": "psu/voltage" },
    { "name": "iout", "path": "psu/current" },
    { "name": "sig_freq", "path": "siggen/frequency" }
  ]
}
